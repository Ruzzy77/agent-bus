{
  "schemaVersion": "wakeup-profile.v1",
  "name": "claude-runner-inbox",
  "mode": "inbox",
  "agent": "claude",
  "kinds": ["request"],
  "command": "AGENT_RUNNER_COMMAND=\"$(agentbus examples adapters/claude-runner.py)\" \"$(agentbus examples adapters/run-agent.sh)\"",
  "intervalSeconds": 5,
  "maxSeconds": 0,
  "execTimeout": 0,
  "markDelivered": true,
  "allowSensitive": false,
  "requiredEnv": []
}
