{
  "schemaVersion": "wakeup-profile.v1",
  "name": "agent-runner-inbox",
  "mode": "inbox",
  "agent": "my-agent",
  "kinds": ["request"],
  "command": "$(agentbus examples adapters/run-agent.sh)",
  "intervalSeconds": 5,
  "maxSeconds": 0,
  "execTimeout": 0,
  "markDelivered": true,
  "allowSensitive": false,
  "requiredEnv": ["AGENT_RUNNER_COMMAND"]
}
