{
  "schemaVersion": "wakeup-profile.v1",
  "name": "openai-compatible-events",
  "mode": "events",
  "types": ["message.created", "ticket.created", "task.created"],
  "command": "$(agentbus examples adapters/openai-compatible.sh)",
  "intervalSeconds": 1,
  "maxSeconds": 0,
  "execTimeout": 120,
  "allowSensitive": false,
  "requiredEnv": [
    "OPENAI_COMPAT_ENDPOINT",
    "OPENAI_COMPAT_MODEL",
    "OPENAI_COMPAT_API_KEY",
    "OPENAI_COMPAT_RESPONSE_TO"
  ]
}
